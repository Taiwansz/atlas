# Atlas Environment Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real credentials

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
GRAPHQL_URL=http://localhost:3002

# =============================================================================
# DATABASES
# =============================================================================

# PostgreSQL (Primary Database)
DATABASE_URL=postgresql://atlas_user:atlas_password@localhost:5432/atlas_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Neo4j (Knowledge Graph)
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=atlas_neo4j_password
NEO4J_DATABASE=atlas

# Redis (Cache & Sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# AI PROVIDERS
# =============================================================================

# NVIDIA (Web discovery and blueprint compiler)
NVIDIA_API_KEY=
ATLAS_AI_MODEL=deepseek-ai/deepseek-v4-flash

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google AI (Gemini)
GOOGLE_AI_API_KEY=AIza...
GOOGLE_AI_DEFAULT_MODEL=gemini-1.5-pro

# Mistral
MISTRAL_API_KEY=...

# Ollama (Local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# AWS Bedrock (Enterprise)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_DEFAULT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Supabase (browser-safe public configuration; never expose the service-role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# OAuth2 / Keycloak
AUTH_KEYCLOAK_URL=http://localhost:8080
AUTH_KEYCLOAK_REALM=atlas
AUTH_KEYCLOAK_CLIENT_ID=atlas-app
AUTH_KEYCLOAK_CLIENT_SECRET=

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# MESSAGING
# =============================================================================

# Apache Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=atlas-dev
KAFKA_GROUP_ID=atlas-consumers
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# =============================================================================
# OBSERVABILITY
# =============================================================================

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=atlas-api
OTEL_ENVIRONMENT=development
OTEL_TRACES_SAMPLER=always_on

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# STORAGE
# =============================================================================

# S3-compatible storage (MinIO for dev, S3 for prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas-dev
S3_REGION=us-east-1

# =============================================================================
# SECRETS MANAGEMENT
# =============================================================================

# HashiCorp Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_NAMESPACE=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_RESEARCH_ENGINE=true
FEATURE_RED_TEAM=false
FEATURE_SIMULATION=false
FEATURE_MARKETPLACE=false
FEATURE_EVOLUTION_ENGINE=false

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AI_CALLS_PER_MINUTE=50

# =============================================================================
# DEVELOPMENT
# =============================================================================
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
ENABLE_QUERY_LOGGING=false
ATLAS_TELEMETRY_DISABLED=false

# AI Cost Budget (USD per day - safety limit for development)
AI_DAILY_BUDGET_USD=10.00
AI_COST_ALERT_THRESHOLD_USD=5.00
