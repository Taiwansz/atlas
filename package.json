{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas Engineering Operating System — Transform ideas into world-class software",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "nx run-many --target=dev --all --parallel=5",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "test": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test",
    "test:coverage": "nx run-many --target=test --all -- --coverage",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "typecheck": "nx run-many --target=typecheck --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "release": "nx release",
    "clean": "nx run-many --target=clean --all && rimraf node_modules",
    "atlas": "nx run @atlas/cli:dev",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@nx/eslint": "19.8.14",
    "@nx/eslint-plugin": "19.8.14",
    "@nx/jest": "19.8.14",
    "@nx/js": "19.8.14",
    "@nx/next": "19.8.14",
    "@nx/node": "19.8.14",
    "@nx/workspace": "19.8.14",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "nx": "19.8.14",
    "patch-package": "^8.0.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "nx": {
    "includedScripts": []
  }
}
