{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas Engineering Operating System — Transform ideas into world-class software",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "nx run-many --target=dev --all --parallel=5",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "test": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test",
    "test:coverage": "nx run-many --target=test --all -- --coverage",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "typecheck": "nx run-many --target=typecheck --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "release": "nx release",
    "clean": "nx run-many --target=clean --all && rimraf node_modules",
    "atlas": "nx run @atlas/cli:dev",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@nx/eslint": "19.8.14",
    "@nx/eslint-plugin": "19.8.14",
    "@nx/jest": "19.8.14",
    "@nx/js": "19.8.14",
    "@nx/next": "19.8.14",
    "@nx/node": "19.8.14",
    "@nx/workspace": "19.8.14",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@testing-library/react": "15.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.0",
    "nx": "19.8.14",
    "patch-package": "^8.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tslib": "^2.3.0"
  }
}
